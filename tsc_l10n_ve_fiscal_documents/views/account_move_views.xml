<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_ve_fiscal" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.ve.fiscal</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="verify_fiscal_integrity" string="Verificar Integridad Fiscal" type="object" groups="tsc_l10n_ve_fiscal_compliance.group_tsc_l10n_ve_fiscal_manager"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Fiscal Venezuela" name="fiscal_venezuela">
                    <group>
                        <group string="Datos de Transmisión">
                            <field name="fiscal_document_number" readonly="1"/>
                            <field name="fiscal_control_number" readonly="1"/>
                            <field name="fiscal_status" readonly="1"/>
                            <field name="fiscal_transmission_state" readonly="1"/>
                            <field name="fiscal_issued_at" readonly="1"/>
                            <field name="fiscal_locked" readonly="1"/>
                        </group>
                        <group string="Integridad de Datos">
                            <field name="fiscal_hash" readonly="1"/>
                            <field name="fiscal_previous_hash" readonly="1"/>
                            <field name="fiscal_integrity_verified" readonly="1"/>
                            <field name="fiscal_integrity_last_check" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
