<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_session_form_inherit_fiscal" model="ir.ui.view">
        <field name="name">pos.session.form.inherit.fiscal</field>
        <field name="model">pos.session</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_session_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Resumen Fiscal SENIAT">
                    <group>
                        <field name="fiscal_document_count"/>
                        <field name="fiscal_transmission_pending_count"/>
                    </group>
                    <group>
                        <field name="fiscal_total_sales"/>
                        <field name="fiscal_total_tax"/>
                        <field name="fiscal_closing_hash"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
