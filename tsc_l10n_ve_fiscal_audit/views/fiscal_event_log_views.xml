<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiscal_event_log_tree" model="ir.ui.view">
        <field name="name">fiscal.event.log.tree</field>
        <field name="model">fiscal.event.log</field>
        <field name="arch" type="xml">
            <list string="Bitácora de Eventos Fiscales" create="false" edit="false" delete="false">
                <field name="create_date" string="Fecha y Hora"/>
                <field name="user_id"/>
                <field name="event_type"/>
                <field name="model_name"/>
                <field name="description"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_fiscal_event_log_form" model="ir.ui.view">
        <field name="name">fiscal.event.log.form</field>
        <field name="model">fiscal.event.log</field>
        <field name="arch" type="xml">
            <form string="Evento Fiscal" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="create_date" string="Fecha y Hora" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="event_type" readonly="1"/>
                        </group>
                        <group>
                            <field name="model_name" readonly="1"/>
                            <field name="record_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiscal_event_log" model="ir.actions.act_window">
        <field name="name">Bitácora de Auditoría Fiscal</field>
        <field name="res_model">fiscal.event.log</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fiscal_event_log_action" 
              name="Auditoría de Eventos" 
              parent="tsc_l10n_ve_fiscal_compliance.menu_l10n_ve_fiscal_root" 
              action="action_fiscal_event_log" 
              sequence="30"/>
</odoo>
