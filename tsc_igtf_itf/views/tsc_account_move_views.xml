<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record model="ir.ui.view" id="tsc_account_move_form_view">
            <field name="name">tsc.account.move.form.inherit</field>
            <field name="model">account.move</field> 
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_payments_widget']" position="after">
                    <field name="tsc_total_igtf" invisible="move_type not in ('out_invoice', 'in_invoice')"/>
                    <field name="tsc_total_with_igtf" invisible="move_type not in ('out_invoice', 'in_invoice')"/>
                </xpath>                 
            </field>
        </record>   
        <record model="ir.ui.view" id="tsc_account_out_move_tree_view">
            <field name="name">tsc.account.out.move.tree.inherit</field>
            <field name="model">account.move</field> 
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="tsc_total_igtf" sum="Total" optional="hide"/>
                </xpath>              
            </field>
        </record>  
        <record model="ir.ui.view" id="tsc_account_in_move_tree_view">
            <field name="name">tsc.account.in.move.tree.inherit</field>
            <field name="model">account.move</field> 
            <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="tsc_supplier_total_igtf" string="Total IGTF" sum="Total" optional="hide"/>
                </xpath>              
            </field>
        </record> 
    </data>
</odoo>

