<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <data>
        <record model="ir.ui.view" id="tsc_account_journal_form_view">
            <field name="name">tsc.account.journal.form.inherit</field>
            <field name="model">account.journal</field> 
            <field name="inherit_id" ref="account.view_account_journal_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='advanced_settings']" position="after">
                    <page name="igtf_page" string="Banking ITF" invisible="type not in ['bank']">
                        <group>
                            <field name="tsc_itf_account_helper" invisible="True"/>
                            <field name="tsc_generate_ITF" widget="toggle_button"/>
                            <field name="tsc_ITF_account_expense" widget="many2one" required="tsc_generate_ITF" style="width:40% !important" options="{'no_create': True, 'no_open': True, 'no_create_edit': True, 'no_quick_create': True}"/>
                            <field name="tsc_itf_percentage" required="tsc_generate_ITF" style="width:40% !important"/>
                        </group>
                    </page>                    
                </xpath>
            </field>
        </record>   


    </data>
</odoo>

