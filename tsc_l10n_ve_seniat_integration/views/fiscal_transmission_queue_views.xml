<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiscal_transmission_queue_tree" model="ir.ui.view">
        <field name="name">fiscal.transmission.queue.tree</field>
        <field name="model">fiscal.transmission.queue</field>
        <field name="arch" type="xml">
            <tree string="Cola de Transmisión Fiscal" decoration-danger="state in ('failed', 'rejected')" decoration-success="state == 'accepted'" decoration-info="state == 'pending'">
                <field name="name"/>
                <field name="move_id"/>
                <field name="document_type"/>
                <field name="state"/>
                <field name="attempt_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <record id="view_fiscal_transmission_queue_form" model="ir.ui.view">
        <field name="name">fiscal.transmission.queue.form</field>
        <field name="model">fiscal.transmission.queue</field>
        <field name="arch" type="xml">
            <form string="Transmisión Fiscal">
                <header>
                    <button name="action_transmit" string="Transmitir Manualmente" type="object" class="oe_highlight" invisible="state not in ('pending','failed')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="move_id" readonly="1"/>
                            <field name="document_type" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="attempt_count" readonly="1"/>
                            <field name="max_attempts" readonly="1"/>
                            <field name="last_attempt_at" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload">
                            <field name="payload" widget="text"/>
                            <group>
                                <field name="payload_hash"/>
                            </group>
                        </page>
                        <page string="Respuestas">
                            <field name="response_ids">
                                <tree>
                                    <field name="received_at"/>
                                    <field name="response_code"/>
                                    <field name="response_message"/>
                                    <field name="accepted"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Error Log" invisible="error_message == False">
                            <field name="error_message" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiscal_transmission_queue" model="ir.actions.act_window">
        <field name="name">Cola de Transmisión Fiscal</field>
        <field name="res_model">fiscal.transmission.queue</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_fiscal_transmission_queue_action" 
              name="Cola de Transmisión" 
              parent="tsc_l10n_ve_fiscal_compliance.menu_l10n_ve_fiscal_root" 
              action="action_fiscal_transmission_queue" 
              sequence="20"/>
</odoo>
