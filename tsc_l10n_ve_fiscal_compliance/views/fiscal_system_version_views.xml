<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiscal_system_version_form" model="ir.ui.view">
        <field name="name">fiscal.system.version.form</field>
        <field name="model">fiscal.system.version</field>
        <field name="arch" type="xml">
            <form string="Versión del Sistema">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre de la Versión"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="version"/>
                            <field name="release_date"/>
                            <field name="is_authorized_version"/>
                        </group>
                        <group>
                            <field name="authorization_reference"/>
                            <field name="checksum"/>
                            <field name="git_commit_hash"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fiscal_system_version" model="ir.actions.act_window">
        <field name="name">Versiones del Sistema</field>
        <field name="res_model">fiscal.system.version</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_fiscal_system_version_action" 
              name="Versiones del Sistema" 
              parent="menu_l10n_ve_fiscal_config" 
              action="action_fiscal_system_version" 
              sequence="3"/>
</odoo>
